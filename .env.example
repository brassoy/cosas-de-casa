# ============================================================================
# Cosas de Casa — variables de entorno (PLANTILLA)
# Copia este archivo a `.env` y rellena los valores. NUNCA commitees `.env`.
# ============================================================================

# ---- Supabase local (valores emitidos por `pnpm db:start`) ------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ---- API --------------------------------------------------------------------
API_PORT=3000
API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
JWT_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
JWT_ISSUER=http://127.0.0.1:54321/auth/v1
JWT_AUDIENCE=authenticated

# ---- IA ---------------------------------------------------------------------
# Chat / extraccion de voz: endpoint compatible-Anthropic de MiniMax.
AI_PROVIDER=minimax
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2
# Embeddings para el dedup semantico: modelo LOCAL (sin clave).
EMBEDDINGS_PROVIDER=local-e5
EMBEDDINGS_MODEL=intfloat/multilingual-e5-small

# ---- Google OAuth (PENDIENTE de credenciales: login social + Calendar) ------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Web (Vite) -------------------------------------------------------------
VITE_API_URL=http://127.0.0.1:3000
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
VITE_LINKEDIN_URL=https://www.linkedin.com/in/pabloruizsanmiguel/
