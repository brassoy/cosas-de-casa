# =============================================================================
# Cosas de Casa — plantilla del .env de PRODUCCIÓN  (referencia)
# =============================================================================
# El bootstrap.sh genera el .env REAL en /opt/cosasdecasa/.env. Los valores
# <GENERADO> los crea con openssl en el droplet y los persiste en
# /mnt/cosasdecasa-data/secrets.env (estables entre re-ejecuciones). Las keys de
# Supabase (ANON/SERVICE_ROLE) se DERIVAN firmando JWT HS256 con el JWT_SECRET.
# Los <RELLENAR> los completas tú tras el primer deploy.
#
# Este archivo es SOLO documentación: ajusta valores en /opt/cosasdecasa/.env y
# rehaz el build de la web (las VITE_* se hornean) — ver README.
# =============================================================================

# ── Compose / Supabase self-hosted ───────────────────────────────────────────
APP_DOMAIN=casa.tudominio.com         # lo inyecta el bootstrap desde Terraform
ACME_EMAIL=tu-email@tudominio.com
POSTGRES_DB=postgres
POSTGRES_PASSWORD=<GENERADO>          # openssl rand -hex 24
JWT_SECRET=<GENERADO>                 # openssl rand -hex 32 (firma TODOS los JWT de Supabase)
JWT_EXP=3600
SECRET_KEY_BASE=<GENERADO>            # openssl rand -hex 32 (Realtime / Phoenix)
ANON_KEY=<DERIVADO>                   # JWT HS256 { role: anon } firmado con JWT_SECRET
SERVICE_ROLE_KEY=<DERIVADO>           # JWT HS256 { role: service_role } firmado con JWT_SECRET

# SMTP de GoTrue (RELLENAR si quieres envío real de correos de Auth):
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=no-reply@casa.tudominio.com

# ── API NestJS (apps/api — validado por Zod en src/config/env.config.ts) ─────
NODE_ENV=production
API_PORT=3000
API_CORS_ORIGINS=https://casa.tudominio.com
# Rol NORMAL que RESPETA RLS (NO service_role):
DATABASE_URL=postgres://authenticator:<GENERADO>@db:5432/postgres
SUPABASE_URL=https://casa.tudominio.com
SUPABASE_PUBLISHABLE_KEY=<DERIVADO>           # = ANON_KEY
SUPABASE_SECRET_KEY=<DERIVADO>                # = SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=<DERIVADO>          # admin: borra usuarios de Auth en la baja GDPR
# Verificación del Bearer en HS256 con el secreto compartido de Supabase self-hosted
# (= JWT_SECRET). En Supabase Cloud se deja vacío y se usa JWT_JWKS_URL en su lugar.
SUPABASE_JWT_SECRET=<= JWT_SECRET>
JWT_ISSUER=https://cosasdecasa.hadara.app/auth/v1
JWT_AUDIENCE=authenticated
JOIN_PIN_PEPPER=<GENERADO>                    # >=16 chars; secreto propio en prod

# IA MiniMax (OPCIONAL; sin esto la extracción por IA degrada a HTTP 503):
MINIMAX_BASE_URL=
MINIMAX_API_KEY=
MINIMAX_MODEL=

# Web Push / VAPID (OPCIONAL; sin esto las notificaciones push se omiten):
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@tudominio.com

# ── WEB (apps/web — VITE_*; SE HORNEAN EN `pnpm build`: ANTES del build) ──────
VITE_API_URL=https://casa.tudominio.com
VITE_SUPABASE_URL=https://casa.tudominio.com
VITE_SUPABASE_ANON_KEY=<DERIVADO>             # = ANON_KEY
VITE_GOOGLE_MAPS_API_KEY=<RELLENAR>           # restríngela por referrer HTTP (ver README)
VITE_VAPID_PUBLIC_KEY=<RELLENAR>              # = VAPID_PUBLIC_KEY (si usas push)
