    "db:stop": "pnpm dlx supabase stop",
    "db:reset": "pnpm dlx supabase db reset"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.9.2"
  }
